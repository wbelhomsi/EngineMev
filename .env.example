# === EngineMev Configuration ===
# Halal-compliant Solana MEV backrun arbitrage engine
# Copy to .env and fill in your values

# ─── RPC & Data Streaming ─────────────────────────────────────────────
# Standard Solana JSON-RPC (for blockhash, simulation, getProgramAccounts)
RPC_URL=https://api.mainnet-beta.solana.com

# Yellowstone gRPC Geyser endpoint (replaces dead Jito mempool)
# Providers: Triton (triton.one), Helius (helius.dev), or self-hosted
# Sub-50ms account streaming — this is the primary data source
GEYSER_GRPC_URL=http://localhost:10000
GEYSER_AUTH_TOKEN=

# ─── Jito Bundle Submission ───────────────────────────────────────────
# Block engine URL for JSON-RPC sendBundle
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Auth keypair for Jito (if required by your block engine region)
JITO_AUTH_KEYPAIR=keypair.json
# Relay URL (usually same as block engine)
JITO_RELAY_URL=https://mainnet.block-engine.jito.wtf
# Jito auth UUID (optional — gives priority in auction queue)
# Register at jito.network to get one
# JITO_AUTH_UUID=your-uuid-here

# ─── Searcher Identity ────────────────────────────────────────────────
# Path to your Solana keypair JSON (signs arb txs, pays tips)
# NEVER commit this file. Generate with: solana-keygen new -o searcher.json
SEARCHER_KEYPAIR=searcher.json

# ─── Multi-Relay Fan-Out (optional) ──────────────────────────────────
# Submit same bundle to multiple relays for higher inclusion probability.
# Atomic bundles mean only one lands — the rest are harmless no-ops.
# NOZOMI_RELAY_URL=https://nozomi-relay-url
# BLOXROUTE_RELAY_URL=https://bloxroute-relay-url
# BLOXROUTE_AUTH_HEADER=your-bloxroute-api-key
# ASTRALANE_RELAY_URL=https://astralane-relay-url
# ZEROSLOT_RELAY_URL=https://zeroslot-relay-url

# ─── Strategy Parameters ─────────────────────────────────────────────
# Fraction of estimated profit given as Jito tip (0.0 - 1.0)
# Higher = more likely to land, lower = more profit kept
TIP_FRACTION=0.50

# Minimum net profit (after tip) to submit a bundle, in lamports
# 100000 lamports = 0.0001 SOL. Below this, opportunity is rejected.
# This is the LAST gate — prefer to fail than send a losing tx.
MIN_PROFIT_LAMPORTS=100000

# Maximum hops in arb route (2 = A→B→A, 3 = A→B→C→A)
# More hops = more opportunities but higher gas + slippage risk
MAX_HOPS=3

# ─── Safety ───────────────────────────────────────────────────────────
# true = log opportunities without submitting bundles (default)
# Set to false only when you're ready to go live with real SOL
DRY_RUN=true

# ─── LST Arbitrage (Phase 2) ────────────────────────────────────────
# Enable LST rate arbitrage (jitoSOL, mSOL, bSOL cross-DEX + Sanctum)
LST_ARB_ENABLED=true
# Minimum spread in basis points to consider an LST arb route
# LST spreads are thin (2-20 bps) — set this lower than MIN_PROFIT_LAMPORTS
LST_MIN_SPREAD_BPS=5

# ─── Logging ──────────────────────────────────────────────────────────
# JSON structured logging. Adjust per-module verbosity:
RUST_LOG=solana_mev_bot=debug,info
