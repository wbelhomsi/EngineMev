# === EngineMev Configuration ===
# Halal-compliant Solana MEV backrun arbitrage engine
# Copy to .env and fill in your values

# ─── RPC & Data Streaming ─────────────────────────────────────────────
# Standard Solana JSON-RPC (for blockhash, simulation, getProgramAccounts)
RPC_URL=https://api.mainnet-beta.solana.com

# Yellowstone gRPC Geyser endpoint (replaces dead Jito mempool)
# Providers: Triton (triton.one), Helius (helius.dev), or self-hosted
# Sub-50ms account streaming — this is the primary data source
GEYSER_GRPC_URL=http://localhost:10000
GEYSER_AUTH_TOKEN=

# ─── Jito Bundle Submission ───────────────────────────────────────────
# Block engine URL for JSON-RPC sendBundle
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Auth keypair for Jito (if required by your block engine region)
JITO_AUTH_KEYPAIR=keypair.json
# Relay URL (usually same as block engine)
JITO_RELAY_URL=https://mainnet.block-engine.jito.wtf
# Jito auth UUID (optional — gives priority in auction queue)
# Register at jito.network to get one
# JITO_AUTH_UUID=your-uuid-here

# ─── Searcher Identity ────────────────────────────────────────────────
# Path to your Solana keypair JSON (signs arb txs, pays tips)
# NEVER commit this file. Generate with: solana-keygen new -o searcher.json
SEARCHER_KEYPAIR=searcher.json

# ─── Multi-Relay Fan-Out (optional) ──────────────────────────────────
# Submit same bundle to multiple relays for higher inclusion probability.
# Atomic bundles mean only one lands — the rest are harmless no-ops.
# Rate limits are per-relay (enforced in code):
#   Jito: 1 TPS (unauth), Astralane: 40 TPS, Nozomi/bloXroute/ZeroSlot: 5 TPS
#
# NOZOMI_RELAY_URL=https://nozomi-relay-url
# NOZOMI_TPS=5
# BLOXROUTE_RELAY_URL=https://bloxroute-relay-url
# BLOXROUTE_AUTH_HEADER=your-bloxroute-api-key
# BLOXROUTE_TPS=5
# Astralane — FRA endpoint with revertProtection for zero-loss
# ASTRALANE_RELAY_URL=http://fr.gateway.astralane.io/iris
# ASTRALANE_API_KEY=your-api-key
# ASTRALANE_TPS=40
# ZEROSLOT_RELAY_URL=https://zeroslot-relay-url
# ZEROSLOT_TPS=5
#
# Jito rate limit (hardcoded 1 TPS unauth, higher with UUID)
JITO_TPS=1
# ZEROSLOT_RELAY_URL=https://zeroslot-relay-url

# ─── Strategy Parameters ─────────────────────────────────────────────
# Fraction of estimated profit given as Jito tip (0.0 - 1.0)
# Higher = more likely to land, lower = more profit kept
TIP_FRACTION=0.50

# Minimum net profit (after tip) to submit a bundle, in lamports
# 100000 lamports = 0.0001 SOL. Below this, opportunity is rejected.
# This is the LAST gate — prefer to fail than send a losing tx.
MIN_PROFIT_LAMPORTS=100000

# Slippage tolerance on estimated profit (0.0 - 1.0). Default 0.25 = 25%.
# With 0.25, a 1 SOL estimated profit is treated as 0.75 SOL for tipping and min_amount_out.
SLIPPAGE_TOLERANCE=0.25

# Maximum hops in arb route (2 = A→B→A, 3 = A→B→C→A)
# More hops = more opportunities but higher gas + slippage risk
MAX_HOPS=3

# ─── Safety ───────────────────────────────────────────────────────────
# true = log opportunities without submitting bundles (default)
# Set to false only when you're ready to go live with real SOL
DRY_RUN=true

# ─── LST Arbitrage (Phase 2) ────────────────────────────────────────
# Enable LST rate arbitrage (jitoSOL, mSOL, bSOL cross-DEX + Sanctum)
LST_ARB_ENABLED=true
# Minimum spread in basis points to consider an LST arb route
# LST spreads are thin (2-20 bps) — set this lower than MIN_PROFIT_LAMPORTS
LST_MIN_SPREAD_BPS=5

# ─── Metrics & Observability (optional) ──────────────────────────────
# Prometheus /metrics HTTP endpoint (disabled if unset)
# METRICS_PORT=9090
# OTLP HTTP endpoint for tracing spans (disabled if unset)
# OTLP_ENDPOINT=http://localhost:4318
# Service name in traces
# OTLP_SERVICE_NAME=mev-engine

# ─── Logging ──────────────────────────────────────────────────────────
# JSON structured logging. Adjust per-module verbosity:
RUST_LOG=solana_mev_bot=debug,info
# On-chain arb-guard profit verification (deployed to mainnet)
# ARB_GUARD_PROGRAM_ID=CbjPG5TEEhZGXsA8prmJPfvgH51rudYgcubRUtCCGyUw

# ─── CEX-DEX Arbitrage (cexdex binary, Model A, SOL/USDC) ─────────────

# Separate wallet for clean P&L isolation
CEXDEX_SEARCHER_KEYPAIR=cexdex-searcher.json
# CEXDEX_SEARCHER_PRIVATE_KEY=  # optional alternative to keypair file

# Binance WS
CEXDEX_BINANCE_WS_URL=wss://stream.binance.com:9443/ws
# Max age of the Binance bookTicker snapshot before the detector refuses to act.
# Lower = safer (won't act on stale CEX prices); higher = permissive in quiet
# market windows. 200ms is 2-3× Binance's typical inter-tick gap for SOL/USDC.
CEXDEX_CEX_STALENESS_MS=200

# Pools to monitor (comma-separated DexType:pubkey)
# DexType: RaydiumAmm, RaydiumCp, RaydiumClmm, OrcaWhirlpool, MeteoraDlmm, MeteoraDammV2
CEXDEX_POOLS=RaydiumCp:<pool_pubkey>,OrcaWhirlpool:<pool_pubkey>

# Strategy
CEXDEX_MIN_SPREAD_BPS=15
CEXDEX_MIN_PROFIT_USD=0.10
CEXDEX_MAX_TRADE_SIZE_SOL=10.0
# Max fraction of TOTAL portfolio (SOL + USDC in SOL-equiv) to spend per trade.
# Prevents draining one side of the book when the available-side balance is
# well below max_trade_size_sol. 0.20 = at most 20% per trade.
CEXDEX_MAX_POSITION_FRACTION=0.20
# Dedup: same (pool, direction) can't re-emit within this window.
# Prevents Geyser-tick bursts from producing back-to-back duplicate submits.
CEXDEX_DEDUP_WINDOW_MS=500
# Global cooldown: no ANY route emits for this window after a dispatch.
# Belt-and-suspenders against multi-pool bursts.
CEXDEX_GLOBAL_SUBMIT_COOLDOWN_MS=1500
CEXDEX_SLIPPAGE_TOLERANCE=0.25
# Fraction of slippage-adjusted profit offered as tip (separate from main engine's TIP_FRACTION).
# CEX-DEX edges are thin — lower tip fraction (e.g. 0.30) keeps more profit for us.
CEXDEX_TIP_FRACTION=0.30

# Inventory gates
CEXDEX_HARD_CAP_RATIO=0.80
CEXDEX_PREFERRED_LOW=0.40
CEXDEX_PREFERRED_HIGH=0.60
CEXDEX_SKEWED_PROFIT_MULTIPLIER=2.0

# Safety
CEXDEX_DRY_RUN=true
CEXDEX_POOL_TTL_SECS=5

# Metrics (separate port from main engine)
CEXDEX_METRICS_PORT=9091

# ─── Durable-Nonce Relay Fan-Out (2026-04-17) ─────────────────────────
# Nonce accounts for multi-relay non-equivocation. Each account:
#   - System Program owned
#   - Initialized with authority == searcher wallet
#   - ~1.4M lamports rent per account
# Leave empty to disable fan-out (Jito-only mode). Comma-separated list.
CEXDEX_SEARCHER_NONCE_ACCOUNTS=

# Per-relay tip fractions. Override CEXDEX_TIP_FRACTION on a per-relay
# basis. Useful because Jito runs a per-slot auction while Astralane
# forwards to shredstream — different economics, different optimal tips.
# Omit to inherit CEXDEX_TIP_FRACTION.
# CEXDEX_TIP_FRACTION_JITO=0.25
# CEXDEX_TIP_FRACTION_ASTRALANE=0.10
# CEXDEX_TIP_FRACTION_NOZOMI=0.10
# CEXDEX_TIP_FRACTION_BLOXROUTE=0.10
# CEXDEX_TIP_FRACTION_ZEROSLOT=0.10
