    {
      "type": "timeseries",
      "title": "Opportunities / Attempted / Confirmed (cumulative)",
      "description": "Detector hits, bundles dispatched, and bundles confirmed on-chain. Gap between attempted and confirmed = bundles lost to Jito rate limits, auction losses, or on-chain tx failures.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "cexdex_opportunities_total", "refId": "A", "legendFormat": "Opportunities (detected)" },
        { "expr": "cexdex_bundles_attempted_total", "refId": "B", "legendFormat": "Attempted (dispatched)" },
        { "expr": "cexdex_bundles_confirmed_total", "refId": "C", "legendFormat": "Confirmed (landed)" },
        { "expr": "cexdex_bundles_attempted_total - cexdex_bundles_confirmed_total", "refId": "D", "legendFormat": "Dropped / lost auction" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "type": "stat",
      "title": "Attempted P&L (if all landed)",
      "description": "Sum of sim net_profit_usd over every dispatched bundle — an upper bound of what we could have made. Gap vs realized = money lost to rate limits + auction losses.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "cexdex_attempted_profit_usd_micros_total / 1000000", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "yellow", "value": null } ] },
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Landing Rate",
      "description": "Confirmed bundles / attempted bundles. Low rate = Jito auction losses or rate-limiting.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "cexdex_bundles_confirmed_total / cexdex_bundles_attempted_total", "refId": "A", "instant": true }
